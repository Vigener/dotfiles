{
	"Table": {
		"prefix": "table",
		"body": [
			"| $1 | $2 |",
			"| --- | --- |",
			"| $3 | $4 |",
			"| $5 | $6 |"
		],
		"description": "Table"
	},
	"Row":{
		"prefix": "row",
		"body": [
			"| $1 | $2 |"
		],
		"description": "テーブルの行を追加"
	},
	"Title for Report": {
		"prefix": "title",
		"body": [
			"<!-- レポート タイトル部分 -->",
			"<div style='text-align:center'>",
			"<div style='font-size:1.5rem'>$1</div>",
			"<div style='font-size:1rem'>202310970 五十嵐尊人</div>",
			"<br />",
			"<br />",
			"</div>",
			"<!--  -->",
			"",
			"$2",
		],
		"description": "Title for Report"
	},
	"波括弧": {
		"prefix": "namikakko",
		"body": [
			"\\lbrace $1 \\rbrace"
		],
		"description": "{ } (波括弧)"
	},
	"Marp用のレイアウトCSS": {
		"prefix": "marp-layout-css",
		"body": [
			"style: |",
			"    :root {",
			"        --fw: 1;",
			"        }",
			"    /* ----- レイアウト ----- */",
			"    .flex {",
			"        display: flex;",
			"        gap: 1em;",
			"    }",
			"    .sa {",
			"        justify-content: space-around;",
			"        /* border: 8px dashed rgb(15, 166, 226);",
			"        background-color: rgb(222, 244, 255); */",
			"    }",
			"    .sb {",
			"        justify-content: space-between;",
			"        /* border: 8px dashed rgb(21, 17, 255);",
			"        background-color: rgb(222, 244, 255); */",
			"    }",
			"    .sa div,",
			"    .sb div {",
			"        margin: 0.1em;",
			"        /* border: 8px dashed rgb(80, 177, 109);",
			"        background-color: rgb(227, 250, 237); */",
			"    }",
			"    .fw div {",
			"        flex: var(--fw);",
			"        /* background-color: rgb(244, 238, 255);",
			"        border: 8px dashed rgb(244, 238, 255); */",
			"    }",
			"    /* ----- ここまで ----- */",
			"    ",
			"    /* ----- スライド番号 ----- */",
			"    section {",
			"        counter-reset: slide;",
			"    }",
			"    section:after {",
			"        counter-increment: slide;",
			"        content: 'Slide ' counter(slide);",
			"        position: absolute;",
			"        top: 0.5rem;",
			"        right: 1rem;",
			"        font-size: 0.8rem;",
			"        color: rgba(255, 255, 255, 0.7);",
			"    }",
			"    /* ----- ここまで ----- */",
			""
		],
		"description": "Marp用のレイアウトCSS"
	},
	"Marpレイアウト - 2列(3:2比率)": {
		"prefix": "fw",
		"body": [
			"<div class=\"flex fw\">",
			"<div style=\"--fw: 3;\"> <!-- 左右の比率を設定 -->",
			"",
			"$1",
			"",
			"</div>",
			"<div style=\"--fw: 2;\">",
			"",
			"$2",
			"",
			"</div>",
			"</div>"
		],
		"description": "Marp用の2列レイアウト（3:2の比率）"
	}
}