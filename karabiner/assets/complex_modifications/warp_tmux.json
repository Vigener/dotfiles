{
    "title": "Warp: Tmux Navigation (Ctrl+Option+hjkl to Prefix+Arrows)",
    "rules": [
        {
            "description": "Warpがアクティブな時、Ctrl+Option+[h,j,k,l]を瞬時に[Prefix+矢印]に変換",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "h",
                        "modifiers": {
                            "mandatory": ["left_control", "left_option"]
                        }
                    },
                    "to": [
                        { "key_code": "b", "modifiers": ["left_control"] },
                        { "key_code": "left_arrow" }
                    ],
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": ["^dev\\.warp\\.Warp-Stable$"]
                        }
                    ]
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "j",
                        "modifiers": {
                            "mandatory": ["left_control", "left_option"]
                        }
                    },
                    "to": [
                        { "key_code": "b", "modifiers": ["left_control"] },
                        { "key_code": "down_arrow" }
                    ],
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": ["^dev\\.warp\\.Warp-Stable$"]
                        }
                    ]
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "k",
                        "modifiers": {
                            "mandatory": ["left_control", "left_option"]
                        }
                    },
                    "to": [
                        { "key_code": "b", "modifiers": ["left_control"] },
                        { "key_code": "up_arrow" }
                    ],
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": ["^dev\\.warp\\.Warp-Stable$"]
                        }
                    ]
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "l",
                        "modifiers": {
                            "mandatory": ["left_control", "left_option"]
                        }
                    },
                    "to": [
                        { "key_code": "b", "modifiers": ["left_control"] },
                        { "key_code": "right_arrow" }
                    ],
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": ["^dev\\.warp\\.Warp-Stable$"]
                        }
                    ]
                }
            ]
        }
    ]
}
