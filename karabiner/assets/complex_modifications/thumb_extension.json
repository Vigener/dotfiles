{
  "title": "Thumb Key Extension (Eisuu/Kana Customization)",
  "rules": [
    {
      "description": "英数キーをモディファイア化 (単押しで英数)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "japanese_eisuu",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "eisuu_pressed",
                "value": 1
              }
            }
          ],
          "to_after_key_up": [
            {
              "set_variable": {
                "name": "eisuu_pressed",
                "value": 0
              }
            }
          ],
          "to_if_alone": [
            {
              "key_code": "japanese_eisuu"
            }
          ]
        }
      ]
    },
    {
      "description": "かなキーをモディファイア化 (単押しでかな)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "japanese_kana",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "kana_pressed",
                "value": 1
              }
            }
          ],
          "to_after_key_up": [
            {
              "set_variable": {
                "name": "kana_pressed",
                "value": 0
              }
            }
          ],
          "to_if_alone": [
            {
              "key_code": "japanese_kana"
            }
          ]
        }
      ]
    },
    {
      "description": "英数コンビネーション (移動・編集系)",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "o"
          },
          "to": [
            {
              "key_code": "delete_or_backspace"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "open_bracket"
          },
          "to": [
            {
              "key_code": "delete_forward"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "q"
          },
          "to": [
            {
              "key_code": "escape"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "spacebar"
          },
          "to": [
            {
              "key_code": "return_or_enter"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "d"
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": ["command"]
            },
            {
              "key_code": "right_arrow",
              "modifiers": ["command", "shift"]
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "h"
          },
          "to": [
            {
              "key_code": "left_arrow"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "j"
          },
          "to": [
            {
              "key_code": "down_arrow"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "k"
          },
          "to": [
            {
              "key_code": "up_arrow"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "l"
          },
          "to": [
            {
              "key_code": "right_arrow"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "s"
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": ["command"]
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "eisuu_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "f"
          },
          "to": [
            {
              "key_code": "right_arrow",
              "modifiers": ["command"]
            }
          ]
        }
      ]
    },
    {
      "description": "かなコンビネーション (メディア操作・アプリ起動)",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "kana_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "p"
          },
          "to": [
            {
              "key_code": "escape"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "kana_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "k"
          },
          "to": [
            {
              "key_code": "play_or_pause"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "kana_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "u"
          },
          "to": [
            {
              "key_code": "volume_up"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "kana_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "i"
          },
          "to": [
            {
              "key_code": "volume_down"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "kana_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "y"
          },
          "to": [
            {
              "key_code": "mute"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "kana_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "m"
          },
          "to": [
            {
              "shell_command": "open -a 'Visual Studio Code'"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "variable_if",
              "name": "kana_pressed",
              "value": 1
            }
          ],
          "from": {
            "key_code": "n"
          },
          "to": [
            {
              "shell_command": "open -a 'Google Chrome'"
            }
          ]
        }
      ]
    },
    {
      "description": "Option + HJKL (Mac標準のウィンドウ/スペース操作へマッピング)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "j",
            "modifiers": {
              "mandatory": ["option"]
            }
          },
          "to": [
            {
              "key_code": "m",
              "modifiers": ["command"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "k",
            "modifiers": {
              "mandatory": ["option"]
            }
          },
          "to": [
            {
              "key_code": "f",
              "modifiers": ["control", "command"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "h",
            "modifiers": {
              "mandatory": ["option"]
            }
          },
          "to": [
            {
              "key_code": "left_arrow",
              "modifiers": ["control"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "l",
            "modifiers": {
              "mandatory": ["option"]
            }
          },
          "to": [
            {
              "key_code": "right_arrow",
              "modifiers": ["control"]
            }
          ]
        }
      ]
    }
  ]
}
