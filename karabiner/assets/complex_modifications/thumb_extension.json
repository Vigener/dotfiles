{
    "title": "Thumb Key Extension (Eisuu/Kana Customization)",
    "rules": [
        {
            "description": "英数キーをモディファイア化 (単押しで英数)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "japanese_eisuu",
                        "modifiers": {
                            "optional": ["any"]
                        }
                    },
                    "to": [
                        {
                            "set_variable": {
                                "name": "eisuu_pressed",
                                "value": 1
                            }
                        }
                    ],
                    "to_after_key_up": [
                        {
                            "set_variable": {
                                "name": "eisuu_pressed",
                                "value": 0
                            }
                        }
                    ],
                    "to_if_alone": [
                        {
                            "key_code": "japanese_eisuu"
                        }
                    ]
                }
            ]
        },
        {
            "description": "かなキーをモディファイア化 (単押しでかな)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "japanese_kana",
                        "modifiers": {
                            "optional": ["any"]
                        }
                    },
                    "to": [
                        {
                            "set_variable": {
                                "name": "kana_pressed",
                                "value": 1
                            }
                        }
                    ],
                    "to_after_key_up": [
                        {
                            "set_variable": {
                                "name": "kana_pressed",
                                "value": 0
                            }
                        }
                    ],
                    "to_if_alone": [
                        {
                            "key_code": "japanese_kana"
                        }
                    ]
                }
            ]
        },
